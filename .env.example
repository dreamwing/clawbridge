# ClawBridge Configuration

# 1. Access Key (Magic Link Password)
# You will use this to login: https://your-domain.com/?key=my_secure_password_123
ACCESS_KEY=my_secure_password_123

# 2. Cloudflare Tunnel Token
# Get this from Cloudflare Zero Trust Dashboard -> Networks -> Tunnels
# Format: eyJhIjoi... (Long Base64 string)
TUNNEL_TOKEN=eyJhIjoi...

# 3. Tunnel Mode
# Set to 'false' (Recommended) if you run the tunnel via Systemd.
# Set to 'true' if you want the Node.js server to manage the tunnel process itself.
ENABLE_EMBEDDED_TUNNEL=false
